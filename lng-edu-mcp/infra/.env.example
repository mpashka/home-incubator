# Copy to .env and adjust for your local environment. Do NOT commit real secrets.
# Consumed by the backend Spring Boot datasource (see backend/src/main/resources/application.yml).
DB_URL=jdbc:postgresql://localhost:5432/lngedu
DB_USERNAME=lngedu
DB_PASSWORD=lngedu

# Phase H — Authorization Server + Google login (see docs/adr/0002-auth-oauth-and-account-linking.md).
# Google OAuth client credentials for federated login. No real values in this environment; the app
# boots with dummy defaults and live Google login is tested by a human later.
GOOGLE_CLIENT_ID=dummy-client-id
GOOGLE_CLIENT_SECRET=dummy-client-secret
# Issuer advertised in the OIDC/OAuth discovery metadata (RFC 9207 `iss`).
AUTH_ISSUER_URI=http://localhost:8080
# MCP resource identifier stamped as the token audience (RFC 8707); Phase I validates it.
MCP_RESOURCE_URI=http://localhost:8080
