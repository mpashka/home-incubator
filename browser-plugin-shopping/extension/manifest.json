{
  "manifest_version": 3,
  "name": "Shopping Collector",
  "version": "0.1.0",
  "description": "Collects marketplace product offers (Ozon, Yandex Market) while you browse, for later AI-driven price/quality analysis.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.ozon.ru/*",
    "https://market.yandex.ru/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Shopping Collector",
    "default_popup": "popup/index.html"
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.ozon.ru/*", "https://market.yandex.ru/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.ozon.ru/*", "https://market.yandex.ru/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
